---
import { SITE } from "@/config/site";
const year = new Date().getFullYear();
---

<footer id="visit" class="border-t border-[var(--color-border)] bg-[var(--color-surface-2)]">
  <div
    class="max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-16 lg:py-20 grid gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-8"
  >
    <div class="lg:col-span-2">
      <p class="font-display text-2xl text-[var(--color-ink)]">{SITE.name}</p>
      <p class="mt-1 text-xs font-medium text-[var(--color-accent)] uppercase tracking-wider">Family-owned &amp; operated since 1987</p>
      <p class="mt-3 text-sm text-[var(--color-ink-muted)] max-w-sm leading-relaxed">
        {SITE.description} Three generations of the Martinez family serving Springfield with care, pride, and a personal touch you won't find at a chain.
      </p>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-ink-faint)]">Location</p>
      <address class="mt-4 not-italic text-sm text-[var(--color-ink-muted)] leading-relaxed">
        {SITE.addressLine1}<br />
        {SITE.cityStateZip}
      </address>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-ink-faint)]">Hours</p>
      <ul class="mt-4 text-sm text-[var(--color-ink-muted)] space-y-1.5">
        <li>{SITE.hoursWeekday}</li>
        <li>{SITE.hoursSaturday}</li>
        <li>{SITE.hoursSunday}</li>
      </ul>
      <p class="mt-6 text-sm">
        <a class="text-[var(--color-accent)] hover:underline font-medium" href={SITE.phoneHref}>{SITE.phone}</a>
        <span class="text-[var(--color-ink-faint)] mx-2">·</span>
        <a class="text-[var(--color-accent)] hover:underline" href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </p>
    </div>
  </div>
  <div class="border-t border-[var(--color-border)]">
    <p
      class="max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-6 text-xs text-[var(--color-ink-faint)] text-center md:text-left"
    >
      © {year} {SITE.name}
    </p>
  </div>
</footer>
