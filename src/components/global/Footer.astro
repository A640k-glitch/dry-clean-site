---
import { SITE } from "@/config/site";
const year = new Date().getFullYear();
---

<footer id="visit" style="background-color: var(--color-footer-bg);">
  <div
    class="max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-16 lg:py-20 grid gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-8"
  >
    <div class="lg:col-span-2">
      <p class="font-display text-2xl text-white">{SITE.name}</p>
      <p class="mt-1 text-xs font-bold text-[var(--color-warm)] uppercase tracking-widest">Family-owned &amp; operated since 1987</p>
      <p class="mt-4 text-sm text-white/65 max-w-sm leading-relaxed">
        {SITE.description} Three generations of the Martinez family—caring for Springfield's clothes with the same personal touch since day one.
      </p>
      <div class="mt-6 flex gap-3">
        <a
          href={SITE.phoneHref}
          class="inline-flex items-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white text-sm font-bold px-5 py-2.5 rounded-full transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call us
        </a>
        <a
          href={`mailto:${SITE.email}`}
          class="inline-flex items-center gap-2 border border-white/20 text-white/80 hover:bg-white/10 text-sm font-semibold px-5 py-2.5 rounded-full transition-colors"
        >
          Email us
        </a>
      </div>
    </div>

    <div>
      <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-warm)]">Find Us</p>
      <address class="mt-4 not-italic text-sm text-white/65 leading-relaxed">
        {SITE.addressLine1}<br />
        {SITE.cityStateZip}
      </address>
      <a
        href={`mailto:${SITE.email}`}
        class="mt-3 block text-sm text-[var(--color-accent)] hover:underline"
      >{SITE.email}</a>
    </div>

    <div>
      <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-warm)]">Hours</p>
      <ul class="mt-4 text-sm text-white/65 space-y-2">
        <li class="flex justify-between gap-4">
          <span class="text-white/40">Mon–Fri</span>
          <span>7:00am – 6:00pm</span>
        </li>
        <li class="flex justify-between gap-4">
          <span class="text-white/40">Saturday</span>
          <span>8:00am – 4:00pm</span>
        </li>
        <li class="flex justify-between gap-4">
          <span class="text-white/40">Sunday</span>
          <span class="text-white/40">Closed</span>
        </li>
      </ul>
      <div class="mt-6 p-4 rounded-xl" style="background-color: var(--color-footer-border);">
        <p class="text-xs text-white/50 uppercase tracking-wider mb-1">Drop off before noon</p>
        <p class="text-sm text-white/80">for same-week turnaround on most orders.</p>
      </div>
    </div>
  </div>

  <div style="border-top: 1px solid var(--color-footer-border);">
    <p
      class="max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-6 text-xs text-white/30 text-center md:text-left"
    >
      © {year} {SITE.name} · Proudly serving Springfield since 1987
    </p>
  </div>
</footer>
