---
import { SITE } from "@/config/site";
---

<section
  class="relative overflow-hidden rounded-sm border border-[var(--color-border)] bg-[var(--color-surface-2)]"
  aria-labelledby="cta-heading"
>
  <div class="max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-16 lg:py-20 lg:flex lg:items-center lg:justify-between lg:gap-16">
    <div class="max-w-xl">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-accent)]">We're here for you</p>
      <h2
        id="cta-heading"
        class="mt-2 font-display text-3xl sm:text-4xl text-[var(--color-ink)] text-balance leading-tight"
      >
        Give us a call—we'd love to help
      </h2>
      <p class="mt-4 text-[var(--color-ink-muted)] leading-relaxed">
        Drop off before noon for same-week service on most orders. We handle rush requests, tricky stains, and last-minute alterations with the same care we give everything else. Just ask.
      </p>
      <ul class="mt-5 space-y-2 text-sm text-[var(--color-ink-muted)]">
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          100% satisfaction guaranteed
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Rush service available on request
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Free stain treatment with every order
        </li>
      </ul>
    </div>
    <div class="mt-10 lg:mt-0 flex flex-col sm:flex-row gap-4 shrink-0">
      <a
        href={SITE.phoneHref}
        class="inline-flex items-center justify-center min-h-12 px-8 text-sm font-semibold text-white bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] rounded-sm transition-colors"
      >
        {SITE.phone}
      </a>
      <a
        href="/#visit"
        class="inline-flex items-center justify-center min-h-12 px-8 text-sm font-medium text-[var(--color-ink)] border border-[var(--color-border)] bg-[var(--color-surface)] hover:bg-white rounded-sm transition-colors"
      >
        Hours &amp; address
      </a>
    </div>
  </div>
</section>
