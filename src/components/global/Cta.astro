---
import { SITE } from "@/config/site";
---

<section
  class="relative overflow-hidden rounded-2xl"
  style="background-color: var(--color-warm-light); border: 2px solid var(--color-warm-border);"
  aria-labelledby="cta-heading"
>
  <!-- Subtle wave texture -->
  <div
    class="absolute inset-0 opacity-[0.06]"
    style="background-image: radial-gradient(circle, var(--color-warm) 1.5px, transparent 1.5px); background-size: 20px 20px;"
    aria-hidden="true"
  ></div>
  <!-- Decorative blob -->
  <div
    class="absolute -left-20 -bottom-20 w-80 h-80 rounded-full opacity-20"
    style="background: radial-gradient(circle, var(--color-warm), transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-[1600px] mx-auto px-6 sm:px-8 lg:px-12 xl:px-16 py-16 lg:py-20 lg:flex lg:items-center lg:justify-between lg:gap-16">
    <div class="max-w-xl">
      <div class="inline-flex items-center gap-2 rounded-full px-3 py-1 mb-5" style="background-color: var(--color-warm); ">
        <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <span class="text-xs font-bold uppercase tracking-widest text-white">We're here for you</span>
      </div>
      <h2
        id="cta-heading"
        class="font-display text-3xl sm:text-4xl text-balance leading-tight"
        style="color: var(--color-ink);"
      >
        Give us a call—we'd love to help
      </h2>
      <p class="mt-4 leading-relaxed" style="color: var(--color-ink-muted);">
        Drop off before noon for same-week service on most orders. We handle rush requests, tricky stains, and last-minute alterations with the same care we give everything else. Just ask.
      </p>
      <ul class="mt-5 space-y-2 text-sm" style="color: var(--color-ink-muted);">
        <li class="flex items-center gap-2">
          <span class="w-5 h-5 rounded-full flex items-center justify-center shrink-0" style="background-color: var(--color-accent);">
            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
          </span>
          100% satisfaction guaranteed
        </li>
        <li class="flex items-center gap-2">
          <span class="w-5 h-5 rounded-full flex items-center justify-center shrink-0" style="background-color: var(--color-accent);">
            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
          </span>
          Rush service available on request
        </li>
        <li class="flex items-center gap-2">
          <span class="w-5 h-5 rounded-full flex items-center justify-center shrink-0" style="background-color: var(--color-accent);">
            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
          </span>
          Free stain treatment with every order
        </li>
      </ul>
    </div>
    <div class="mt-10 lg:mt-0 flex flex-col sm:flex-row gap-4 shrink-0">
      <a
        href={SITE.phoneHref}
        class="inline-flex items-center justify-center gap-2 min-h-12 px-8 text-sm font-bold text-white rounded-full transition-colors shadow-md"
        style="background-color: var(--color-accent);"
        onmouseover="this.style.backgroundColor='var(--color-accent-hover)'"
        onmouseout="this.style.backgroundColor='var(--color-accent)'"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        {SITE.phone}
      </a>
      <a
        href="/#visit"
        class="inline-flex items-center justify-center min-h-12 px-8 text-sm font-semibold rounded-full transition-colors border-2"
        style="color: var(--color-ink); border-color: var(--color-warm-border); background: white;"
      >
        Hours &amp; address
      </a>
    </div>
  </div>
</section>
