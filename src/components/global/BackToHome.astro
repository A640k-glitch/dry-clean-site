---
interface Props {
  /** Defaults to home page. Use `/#journal` to return to the journal block. */
  href?: string;
  label?: string;
}

const { href = "/", label = "Back to home" } = Astro.props;
---

<nav class="mb-8 lg:mb-10" aria-label="Back to home">
  <a
    href={href}
    class="inline-flex items-center gap-2.5 min-h-11 px-1 -mx-1 rounded-sm text-sm font-bold text-[var(--color-accent)] hover:text-[var(--color-ink)] transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
  >
    <svg
      class="w-5 h-5 shrink-0"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M19 12H5M12 19l-7-7 7-7"></path>
    </svg>
    <span>{label}</span>
  </a>
</nav>
