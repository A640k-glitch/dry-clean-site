---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/config/site";

const title = `Not found · ${SITE.name}`;
const description = "This page does not exist or may have moved.";
---

<BaseLayout title={title} description={description}>
  <section class="max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-28 text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--color-ink-faint)]">404</p>
    <h1 class="mt-4 font-display text-4xl sm:text-5xl text-[var(--color-ink)]">Page not found</h1>
    <p class="mt-6 text-[var(--color-ink-muted)] max-w-md mx-auto leading-relaxed">
      The link may be outdated. Return home for services and the journal.
    </p>
    <a
      href="/"
      class="inline-flex mt-10 items-center justify-center min-h-12 px-8 text-sm font-semibold text-white bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] rounded-sm transition-colors"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
