---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/config/site";

const { frontmatter } = Astro.props;
const pageTitle = `${frontmatter.title} · ${SITE.name}`;
---

<BaseLayout title={pageTitle} description={frontmatter.description}>
  <article class="border-b border-[var(--color-border)]">
    <header
      class="max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 pt-16 lg:pt-24 pb-10 lg:pb-14"
    >
      <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-[var(--color-ink-faint)]">
        Care tips
      </p>
      <h1
        class="mt-4 max-w-4xl font-display text-4xl sm:text-5xl lg:text-[3.25rem] leading-[1.1] text-[var(--color-ink)] text-balance"
      >
        {frontmatter.title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-[var(--color-ink-muted)] leading-relaxed">
        {frontmatter.description}
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[var(--color-ink-faint)]">
        <time datetime={frontmatter.pubDate.toISOString()}>
          {frontmatter.pubDate.toString().slice(0, 10)}
        </time>
        <span aria-hidden="true">·</span>
        <span>{frontmatter.author}</span>
        <span class="hidden sm:inline" aria-hidden="true">·</span>
        <span class="flex flex-wrap gap-2">
          {
            frontmatter.tags.map((tag: string) => (
              <a
                class="text-[var(--color-accent)] hover:underline"
                href={`/tags/${encodeURIComponent(tag)}`}
              >
                {tag}
              </a>
            ))
          }
        </span>
      </div>
    </header>

    <div class="max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <img
        src={frontmatter.image.url}
        alt={frontmatter.image.alt}
        width={1600}
        height={900}
        loading="eager"
        decoding="async"
        class="w-full max-h-[min(70vh,720px)] object-cover rounded-sm"
      />
    </div>

    <div
      class="max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-16 lg:py-24"
    >
      <div
        class="prose prose-lg prose-stone max-w-2xl mx-auto prose-headings:font-display prose-headings:font-normal prose-headings:tracking-tight prose-p:text-[var(--color-ink-muted)] prose-p:leading-relaxed prose-li:text-[var(--color-ink-muted)]"
      >
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
