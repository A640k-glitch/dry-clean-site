---
import BaseHead from "@/components/BaseHead.astro";
import Navigation from "@/components/global/Navigation.astro";
import Footer from "@/components/global/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} canonicalPath={canonicalPath} />
  </head>
  <body
    class="flex flex-col min-h-screen bg-[var(--color-surface)] text-[var(--color-ink)] antialiased"
  >
    <Navigation />
    <main class="flex-grow w-full"><slot /></main>
    <Footer />
  </body>
</html>
